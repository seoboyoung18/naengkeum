# ============================================================================
#  냉큼 배포 환경변수 예시 — 실제 값은 .env 로 복사해 서버에만 두기 (git 커밋 금지)
#    cp .env.example .env  &&  값 채우기  &&  docker compose up -d --build
# ============================================================================

# ----- DB (mysql 컨테이너) -----
DB_NAME=naengkeum
DB_USERNAME=naengkeum
DB_PASSWORD=          # 운영용 강력한 비밀번호
DB_ROOT_PASSWORD=     # mysql root 비밀번호

# ----- 보안 -----
JWT_SECRET=           # 32바이트 이상 임의 문자열 (운영 전용, 새로 생성)

# ----- AI (GMS) -----
OPENAI_API_KEY=       # SSAFY GMS 키

# ----- 프론트 리다이렉트 도메인 (소셜 로그인 성공 후 복귀 주소) -----
#  운영 도메인: https://naengkeum.duckdns.org  (HTTPS 필수 — 구글/카카오 정책)
FRONTEND_BASE_URL=https://naengkeum.duckdns.org

# ----- 소셜 로그인 (보영 담당) -----
#  콘솔에 운영 Redirect URI 등록 필수(로컬용도 같이 유지):
#    구글: https://naengkeum.duckdns.org/login/oauth2/code/google
#    카카오: https://naengkeum.duckdns.org/login/oauth2/code/kakao
#           + 카카오 콘솔 > 플랫폼 > Web 사이트도메인에 https://naengkeum.duckdns.org 추가
#           + 카카오는 client_secret_post 방식 → 콘솔에서 secret 발급 후 "활성화" 해야 검증됨
#  KAKAO_CLIENT_ID 는 카카오 REST API 키.
GOOGLE_CLIENT_ID=changeme
GOOGLE_CLIENT_SECRET=changeme
KAKAO_CLIENT_ID=changeme
KAKAO_CLIENT_SECRET=changeme
